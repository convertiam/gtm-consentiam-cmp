___TESTS___

scenarios:
- name: Default consent without cookie
  code: |-
    mock('getCookieValues', function() { return []; });
    mock('injectScript', function(url, onSuccess, onFailure, id) {
      onSuccess();
    });

    const mockData = {
      apiKey: 'test-key',
      wait_for_update: 500,
      regions: 'eea',
      url_passthrough: true,
      ads_data_redaction: true
    };

    runCode(mockData);

    assertApi('setDefaultConsentState').wasCalled();
    assertApi('updateConsentState').wasNotCalled();
    assertApi('gtmOnSuccess').wasCalled();

- name: Consent restored from cookie calls updateConsentState
  code: |-
    mock('getCookieValues', function() {
      return ['{"v":2,"c":{"n":true,"a":true,"m":false,"p":true},"t":1702900000000}'];
    });
    mock('injectScript', function(url, onSuccess, onFailure, id) {
      onSuccess();
    });

    const mockData = {
      apiKey: 'test-key',
      wait_for_update: 500,
      regions: 'eea',
      url_passthrough: true,
      ads_data_redaction: true
    };

    runCode(mockData);

    assertApi('setDefaultConsentState').wasCalled();
    assertApi('updateConsentState').wasCalled();
    assertApi('gtmOnSuccess').wasCalled();

- name: Unknown cookie format does not call updateConsentState
  code: |-
    mock('getCookieValues', function() {
      return ['{"necessary":true,"analytics":true}'];
    });
    mock('injectScript', function(url, onSuccess, onFailure, id) {
      onSuccess();
    });

    const mockData = {
      apiKey: 'test-key',
      wait_for_update: 500,
      regions: 'eea',
      url_passthrough: true,
      ads_data_redaction: true
    };

    runCode(mockData);

    assertApi('setDefaultConsentState').wasCalled();
    assertApi('updateConsentState').wasNotCalled();
    assertApi('gtmOnSuccess').wasCalled();


___NOTES___

Consentiam CMP v2.2.0
Developed by Convertiam.com
Last updated: 2026-03
https://www.consentiam.eu

Two installation modes:
- AUTOMATIC (recommended): Leave "Config Code" empty.
  The banner fetches its config from the API automatically.
- OPTIMIZED (advanced): Paste your Config Code from dashboard.
  The banner renders instantly without fetch.

Setup:
1. Import this template in GTM (Templates > New > Import)
2. Create a tag with trigger "Consent Initialization - All Pages"
3. Enter your Consentiam API Key
4. (OPTIMIZED only) Paste your Config Code
